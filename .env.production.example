APP_NAME=SchoolSphere
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.example.com

DB_CONNECTION=mysql
DB_HOST=your-db-host
DB_PORT=3306
DB_DATABASE=school_record_manager
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

SESSION_DOMAIN=.example.com
SANCTUM_STATEFUL_DOMAINS=app.example.com,api.example.com
FRONTEND_URL=https://app.example.com

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=schoolsphere
REVERB_APP_KEY=replace-with-secure-key
REVERB_APP_SECRET=replace-with-secure-secret
REVERB_HOST=api.example.com
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=${PORT}